; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Home Sweet Hell"
run/main_scene="uid://dpx5e8nfmffic"
config/features=PackedStringArray("4.4", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://x7olkos3adhq"

[autoload]

GameManager="*res://Scripts/game_manager.gd"
FadeManager="*res://scenes/fade_manager.tscn"
Dialogic="*res://addons/dialogic/Core/DialogicGameHandler.gd"
SaveManager="*res://Scripts/save_manager.gd"

[dialogic]

directories/dch_directory={
"Collar": "res://characters/Collar.dch",
"Luna": "res://characters/Luna.dch",
"Marcus": "res://characters/Marcus.dch",
"Olivia": "res://characters/Olivia.dch",
"Seb": "res://characters/Seb.dch",
"Sophia": "res://characters/Sophia.dch",
"unit_test_character": "res://Tests/Resources/unit_test_character.dch"
}
directories/dtl_directory={
"Conservatory": "res://timelines/Conservatory.dtl",
"Intro": "res://timelines/Intro.dtl",
"Olivia Won": "res://timelines/Olivia Won.dtl",
"OliviaDream": "res://timelines/OliviaDream.dtl",
"OliviaHome": "res://timelines/OliviaHome.dtl",
"OliviaRoute": "res://timelines/OliviaRoute.dtl",
"Park": "res://timelines/Park.dtl",
"Rhythm Dialogue": "res://timelines/Rhythm Dialogue.dtl",
"Rhythm Dialogue 2": "res://timelines/Rhythm Dialogue 2.dtl",
"School": "res://timelines/School.dtl",
"SophiaHome": "res://timelines/SophiaHome.dtl",
"SophiaRoute": "res://timelines/SophiaRoute.dtl"
}
layout/style_directory={
"": "res://New_File.tres",
"End text": "res://style/End text.tres",
"New_File": "res://New_File.tres"
}
glossary/default_case_sensitive=true
layout/style_list=["res://New_File.tres", "res://style/End text.tres"]
layout/default_style="res://New_File.tres"
variables={}
text/letter_speed=0.02
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/autopauses={}
audio/channel_defaults={
"sfx": {
"audio_bus": "",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
}
}
extensions_folder="res://addons/dialogic_additions"
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.5
animations/join_default_wait=true
animations/leave_default_length=0.5
animations/leave_default_wait=true
animations/cross_fade_default_length=0.5
audio/type_sound_bus="OST"
animations/leave_default="Fade Out Down"
text/input_action="dialogic_default_action"
save/autosave=true
save/default_slot="autosave"

[display]

window/size/mode=3
window/size/initial_position_type=0
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

